{
    "name": "palettelive",
    "version": "1.0.0",
    "description": "Extract, edit, and export color palettes from any website live.",
    "private": true,
    "scripts": {
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write \"**/*.{js,json,css,html,md}\"",
        "format:check": "prettier --check \"**/*.{js,json,css,html,md}\"",
        "test": "jest --coverage",
        "test:watch": "jest --watch",
        "validate": "npm run lint && npm run format:check && npm run test",
        "build": "powershell -ExecutionPolicy Bypass -File build.ps1"
    },
    "devDependencies": {
        "@eslint/js": "^9.0.0",
        "eslint": "^9.0.0",
        "prettier": "^3.2.0",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0"
    },
    "engines": {
        "node": ">=22.0.0"
    }
}
